{
    "name": "jsmart/framework",
    "type": "project",
    "description": "JSmart Framework",
    "keywords": ["framework", "jsmart"],
    "authors": [
        {
            "name": "Vadim Shestakov",
            "email": "shestakov2103@gmail.com"
        }
    ],
    "license": "",
    "autoload": {
        "files": [
            "application/Core/Foundation/helpers.php"
        ],
        "psr-4": {
            "App\\": "application",
            "JSmart\\Core\\": "application/Core"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests"
        }
    },
    "require": {
        "php": "^8.0.8",
        "doctrine/dbal": "^3.3",
        "illuminate/collections": "^9.5",
        "illuminate/container": "^9.5",
        "illuminate/database": "^9.5",
        "illuminate/support": "^9.5",
        "symfony/console": "^6.0",
        "symfony/error-handler": "^6.0",
        "symfony/event-dispatcher": "^6.0",
        "symfony/finder": "^6.0",
        "symfony/http-foundation": "^6.0",
        "symfony/mailer": "^6.0",
        "symfony/routing": "^6.0",
        "symfony/var-dumper": "^6.0",
        "twig/twig": "^3.3"
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.0.8"
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "scripts": {
        "test": "phpunit --colors=always"
    }
}
